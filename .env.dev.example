# ─────────────────────────────────────────────────────────────────────────────
# .env.dev.example — LOCAL development
# Copy to .env before running: docker compose up
# ─────────────────────────────────────────────────────────────────────────────

# ── MySQL ──────────────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=dev_root
DB_USER=market_user
DB_PASSWORD=dev_password
DB_NAME=smart_market_dev
DB_SYNCHRONIZE=true

# ── API ────────────────────────────────────────────────────────────────────
PORT=8000
CORS_ORIGIN=http://localhost:3000
