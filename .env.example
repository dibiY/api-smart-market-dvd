# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in your values
# See also: .env.dev.example / .env.recette.example / .env.prod.example
# ─────────────────────────────────────────────────────────────────────────────

# ── MySQL ─────────────────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=changeme_root
DB_HOST=localhost
DB_PORT=3306
DB_USER=market_user
DB_PASSWORD=changeme
DB_NAME=smart_market_dvd
# Set to false in production — use explicit migrations instead
DB_SYNCHRONIZE=true

# ── CORS — frontend origin ────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Backend port ──────────────────────────────────────────────────────────────
PORT=8000

# ── Docker image tag (prod only) ──────────────────────────────────────────────
# IMAGE_TAG=ghcr.io/your-org/api-smart-market-dvd:1.0.0
