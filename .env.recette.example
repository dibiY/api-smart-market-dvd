# ─────────────────────────────────────────────────────────────────────────────
# .env.recette.example — STAGING / RECETTE
# Copy to .env on the recette server before running:
#   docker compose -f docker-compose.yml -f docker-compose.recette.yml up -d
# ─────────────────────────────────────────────────────────────────────────────

# ── MySQL ──────────────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=recette_root_strong_password
DB_USER=market_user
DB_PASSWORD=recette_strong_password
DB_NAME=smart_market_recette
DB_SYNCHRONIZE=true

# ── API ────────────────────────────────────────────────────────────────────
PORT=8000
CORS_ORIGIN=https://recette.your-domain.com
