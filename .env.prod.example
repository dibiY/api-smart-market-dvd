# ─────────────────────────────────────────────────────────────────────────────
# .env.prod.example — PRODUCTION
# Copy to .env on the production server before running:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d
#
# NEVER commit the real .env file. Use a secrets manager (Vault, AWS Secrets
# Manager, GitHub Actions secrets, etc.) to inject values in CI/CD.
# ─────────────────────────────────────────────────────────────────────────────

# ── MySQL ──────────────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=CHANGE_ME_strong_root_password
DB_USER=market_user
DB_PASSWORD=CHANGE_ME_strong_password
DB_NAME=smart_market_prod
DB_SYNCHRONIZE=false     # Migrations must be run explicitly in production

# ── API ────────────────────────────────────────────────────────────────────
PORT=8000
CORS_ORIGIN=https://your-domain.com

# ── Docker image (pre-built by CI/CD pipeline) ─────────────────────────────
IMAGE_TAG=ghcr.io/your-org/api-smart-market-dvd:1.0.0
